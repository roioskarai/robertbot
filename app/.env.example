# ─────────────────────────────────────────────
# Robert — Environment Variables
# Copy to .env.local and fill with real values.
# The app RUNS with placeholders; external calls
# (Supabase / Stripe / Twilio / Resend) only work
# once real keys are provided. With a real
# ANTHROPIC_API_KEY the AI engine + preview work
# end-to-end.
# ─────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Payments ──────────────────────────────────
# Active provider: "grow" (default, recommended for Israel) or "stripe".
PAYMENT_PROVIDER=grow

# Grow / משולם (dashboard → settings → API). Israeli billing + Hebrew tax invoices.
GROW_ENV=sandbox            # sandbox | production
GROW_USER_ID=
GROW_PAGE_CODE=
GROW_API_KEY=
# Shared secret echoed back on the Grow server callback for verification.
GROW_WEBHOOK_SECRET=change-me

# Stripe (optional fallback / international — Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── WhatsApp ──────────────────────────────────
# Active provider: "twilio" (default, fast launch) or "meta" (direct, cheaper).
# Both isolate tenants — each bot sends FROM its own connected number/WABA.
WHATSAPP_PROVIDER=twilio

# Twilio (Console → Account / WhatsApp sender). Phase 1 provider.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Fallback sender for bots without their own connected number (onboarding sandbox).
TWILIO_WHATSAPP_NUMBER=
# Optional: Twilio Verify service SID for phone OTP
TWILIO_VERIFY_SERVICE_SID=

# Meta WhatsApp Cloud API (Phase 2 — direct Tech Provider via Embedded Signup).
# Each tenant connects its OWN Meta Portfolio + WABA → full ban isolation.
META_APP_ID=
META_APP_SECRET=
# Embedded Signup configuration id (Meta App → WhatsApp → Configuration).
META_CONFIG_ID=

# Anthropic Claude (console.anthropic.com)
ANTHROPIC_API_KEY=
# Model id used by the AI engine
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Optional: model override for the operational agents (lib/agents). Falls back to ANTHROPIC_MODEL.
ANTHROPIC_AGENT_MODEL=

# Resend (resend.com → API Keys)
RESEND_API_KEY=
RESEND_FROM=Robert <noreply@robertbot.co.il>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret protecting the cron + agent routes (?secret=... / Authorization: Bearer)
CRON_SECRET=change-me
# Recipient of the daily agent owner report (ops-orchestrator)
OWNER_EMAIL=
