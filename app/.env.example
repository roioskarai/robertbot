# ─────────────────────────────────────────────
# Robert — Environment Variables
# Copy to .env.local and fill with real values.
# The app RUNS with placeholders; external calls
# (Supabase / Stripe / Twilio / Resend) only work
# once real keys are provided. With a real
# ANTHROPIC_API_KEY the AI engine + preview work
# end-to-end.
# ─────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Twilio (Console → Account / WhatsApp sender)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
# Optional: Twilio Verify service SID for phone OTP
TWILIO_VERIFY_SERVICE_SID=

# Anthropic Claude (console.anthropic.com)
ANTHROPIC_API_KEY=
# Model id used by the AI engine
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Resend (resend.com → API Keys)
RESEND_API_KEY=
RESEND_FROM=Robert <noreply@robertbot.co.il>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret protecting the trial cron route (?secret=...)
CRON_SECRET=change-me
